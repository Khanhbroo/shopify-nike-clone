<section>
  <div class="banner-wrapper">
    <div class="slider-text" id="firstText">
      <p>Members: Free Shipping!</p>
    </div>
    <div class="slider-text" id="secondText">
      <p>Save Up To 40%</p>
    </div>
    <div class="slider-text" id="thirdText">
      <p>Get Your Gear Faster</p>
    </div>
  </div>
</section>

<style>
  .banner-wrapper {
    height: 50;
    color: {{ section.settings.text_color }};
    background-color: {{ section.settings.background_color }};
  }

  .slider-text {
    position: absolute;
    top: 115px;
    left: -150%;
    transform: translate(0, 25%);
    transition: left 0.6s ease;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const texts = document.querySelectorAll('.slider-text');
    console.log(texts);
    let currentIndex = 0;

    const slideText = () => {
      const currentText = texts[currentIndex];
      currentText.style.left = '-150%';

      currentIndex = (currentIndex + 1) % texts.length;

      const nextText = texts[currentIndex];
      nextText.style.left = '44%';
    };

    setInterval(slideText, 3000);
  });
</script>

{% schema %}
{
  "name": "banner",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F4F4F4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Banner"
    }
  ]
}
{% endschema %}
