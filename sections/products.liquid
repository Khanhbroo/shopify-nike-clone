<section class="products-section">
  <div class="products-header">
    <h2>{{ collections[section.settings.collection].title | default: 'Featured Products' }}</h2>
    <a href="{{ collections[section.settings.collection].url | default: '/collections/all' }}" class="view-all-link">Shop All</a>
  </div>
  <div class="products-container">
    <div class="products-grid">
      {% for product in collections[section.settings.collection].products limit: 4 %}
        <div class="product-card">
          <a href="{{ product.url }}" class="product-image-link">
            <img class="product-image" width="300" height="300" loading="lazy" src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}">
          </a>
          <div class="product-info">
            <h3 class="product-title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
            <p class="product-price">{{ product.price | money }}</p>
          </div>
        </div>
      {% else %}
        <!-- Placeholder Products for Theme Editor -->
        {% for i in (1..4) %}
          <div class="product-card">
            <div class="product-image-link">
              {{ 'product-' | append: i | placeholder_svg_tag: 'product-image' }}
            </div>
            <div class="product-info">
              <h3 class="product-title"><a href="#">Example Product {{ i }}</a></h3>
              <p class="product-price">$99.00</p>
            </div>
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .products-section {
    padding: 60px 20px;
    max-width: 1600px;
    margin: 0 auto;
  }

  .products-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 30px;
  }

  .products-header h2 {
    font-size: 32px;
    margin: 0;
  }

  .view-all-link {
    color: var(--color-black);
    text-decoration: none;
    font-weight: 600;
    border-bottom: 2px solid transparent;
    transition: border-color var(--transition-fast);
  }
  
  .view-all-link:hover {
    border-color: var(--color-black);
  }

  .products-container {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
  }
  
  .products-container::-webkit-scrollbar {
    display: none; /* Chrome/Safari/Opera */
  }

  .products-grid {
    display: flex;
    gap: 20px;
    min-width: max-content;
  }

  @media (min-width: 1024px) {
    .products-container {
      overflow-x: visible;
    }
    .products-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      min-width: auto;
    }
  }

  .product-card {
    display: flex;
    flex-direction: column;
    width: 280px;
    transition: transform var(--transition-normal);
  }

  @media (min-width: 1024px) {
    .product-card {
      width: auto;
    }
  }

  .product-card:hover {
    transform: translateY(-5px);
  }

  .product-image-link {
    display: block;
    background-color: #ffffff; /* Solid frame for products */
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 15px;
    aspect-ratio: 1 / 1;
    position: relative;
    box-shadow: var(--shadow-sm);
  }

  .product-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 10px;
    transition: transform var(--transition-slow);
  }
  
  .product-image-link svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 20px;
    background-color: transparent;
    transition: transform var(--transition-slow);
    /* No invert filter needed since background is white */
  }
  
  .product-image-placeholder {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: var(--color-gray-200);
    border-radius: 8px;
    margin-bottom: 15px;
  }

  .product-card:hover .product-image,
  .product-card:hover .product-image-link svg {
    transform: scale(1.05);
  }

  .product-info {
    padding: 0 5px;
  }

  .product-title {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    margin: 0 0 5px 0;
    text-transform: none;
  }

  .product-title a {
    color: var(--color-black);
    text-decoration: none;
  }

  .product-price {
    font-weight: 700;
    margin: 0;
    color: var(--color-gray-800);
  }
</style>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
