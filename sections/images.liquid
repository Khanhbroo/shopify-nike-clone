<section class="featured-images">
  <div class="images-grid">
    <div class="image-card">
      <div class="image-bg" style="background-image: url('{% if section.settings.first_image != blank %}{{ section.settings.first_image | image_url }}{% else %}{{ 'first-image-default.png' | asset_url }}{% endif %}');"></div>
      <div class="image-overlay">
        <h2>{{ section.settings.first_text | default: "Men" }}</h2>
        <a href="{{ section.settings.first_link | default: '/collections/men' }}" class="btn-primary">Shop</a>
      </div>
    </div>

    <div class="image-card">
      <div class="image-bg" style="background-image: url('{% if section.settings.second_image != blank %}{{ section.settings.second_image | image_url }}{% else %}{{ 'second-image-default.png' | asset_url }}{% endif %}');"></div>
      <div class="image-overlay">
        <h2>{{ section.settings.second_text | default: "Women" }}</h2>
        <a href="{{ section.settings.second_link | default: '/collections/women' }}" class="btn-primary">Shop</a>
      </div>
    </div>

    <div class="image-card">
      <div class="image-bg" style="background-image: url('{% if section.settings.third_image != blank %}{{ section.settings.third_image | image_url }}{% else %}{{ 'third-image-default.png' | asset_url }}{% endif %}');"></div>
      <div class="image-overlay">
        <h2>{{ section.settings.third_text | default: "Kids" }}</h2>
        <a href="{{ section.settings.third_link | default: '/collections/kids' }}" class="btn-primary">Shop</a>
      </div>
    </div>
  </div>
</section>

<style>
  .featured-images {
    padding: 20px;
    max-width: 1600px;
    margin: 0 auto;
  }

  .images-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  @media (max-width: 768px) {
    .images-grid {
      grid-template-columns: 1fr;
    }
  }

  .image-card {
    position: relative;
    height: 500px;
    overflow: hidden;
    border-radius: 12px;
    cursor: pointer;
    box-shadow: var(--shadow-sm);
  }

  .image-bg {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-size: cover;
    background-position: center;
    transition: transform var(--transition-slow);
  }

  .image-card:hover .image-bg {
    transform: scale(1.08);
  }

  .image-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 30px;
    background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
    color: #ffffff;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .image-overlay h2 {
    font-size: 28px;
    margin-bottom: 15px;
    letter-spacing: 1px;
    color: #ffffff;
  }
</style>

{% schema %}
{
  "name": "Featured Images",
  "settings": [
    {
      "type": "image_picker",
      "id": "first_image",
      "label": "First Image"
    },
    {
      "type": "text",
      "id": "first_text",
      "label": "First Text",
      "default": "Men"
    },
    {
      "type": "url",
      "id": "first_link",
      "label": "First Link"
    },
    {
      "type": "image_picker",
      "id": "second_image",
      "label": "Second Image"
    },
    {
      "type": "text",
      "id": "second_text",
      "label": "Second Text",
      "default": "Women"
    },
    {
      "type": "url",
      "id": "second_link",
      "label": "Second Link"
    },
    {
      "type": "image_picker",
      "id": "third_image",
      "label": "Third Image"
    },
    {
      "type": "text",
      "id": "third_text",
      "label": "Third Text",
      "default": "Kids"
    },
    {
      "type": "url",
      "id": "third_link",
      "label": "Third Link"
    }
  ],
  "presets": [
    {
      "name": "Featured Images"
    }
  ]
}
{% endschema %}
