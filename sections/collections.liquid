<section class="collections-section">
  <div class="collections-header">
    <h2>{{ section.settings.title | default: 'Featured Collections' }}</h2>
  </div>
  <div class="collections-container">
    <div class="collections-grid">
      {% for collection in collections %}
        <div class="collection-card">
          <a href="{{ collection.url }}" class="collection-image-link">
            <img class="collection-image" width="400" height="400" loading="lazy" src="{{ collection.featured_image | image_url: width: 800 }}" alt="{{ collection.title }}">
            <div class="collection-overlay">
              <h3 class="collection-title">{{ collection.title }}</h3>
            </div>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .collections-section {
    padding: 60px 20px;
    max-width: 1600px;
    margin: 0 auto;
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
  }

  .collections-header {
    margin-bottom: 30px;
  }

  .collections-header h2 {
    font-size: 32px;
    margin: 0;
  }

  .collections-container {
    width: 100%;
  }

  .collections-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
  }

  @media (min-width: 768px) {
    .collections-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
  }

  .collection-card {
    display: flex;
    flex-direction: column;
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    box-shadow: var(--shadow-sm);
  }

  .collection-image-link {
    display: block;
    position: relative;
    background-color: var(--color-gray-100);
    overflow: hidden;
  }

  .collection-image {
    width: 100%;
    height: auto;
    object-fit: cover;
    aspect-ratio: 4 / 5;
    transition: transform var(--transition-slow);
    display: block;
  }

  .collection-card:hover .collection-image {
    transform: scale(1.08);
  }

  .collection-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px;
    background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
    color: #ffffff;
  }

  .collection-title {
    font-family: var(--font-heading);
    font-size: 24px;
    margin: 0;
    text-transform: uppercase;
    color: #ffffff;
  }
</style>

{% schema %}
{
  "name": "Collections List",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Featured Collections"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Collections List"
    }
  ]
}
{% endschema %}
