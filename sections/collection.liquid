{% paginate collection.products by 12 %}
  <section class="collection-page-sec">
    <div class="collection-header-wrapper" style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};">
      <div class="collection-header-inner">
        <h1 class="collection-page-title">{{ collection.title }}</h1>
        
        <div class="collection-sort-container">
          <label for="sort-by">Sort By:</label>
          <select id="sort-by" class="sort-select">
            {% assign sort_by = collection.sort_by | default: collection.default_sort_by %}

            {% for option in collection.sort_options %}
              <option
                value="{{option.value}}"
                {% if option.value == sort_by %}
                  selected="selected"
                {% endif %}
              >
                {{ option.name }}
              </option>
            {% endfor %}
          </select>
        </div>
      </div>
    </div>

    <div class="collection-products-container">
      <div class="products-grid">
        {% for product in collection.products %}
          <div class="product-card">
            <a href="{{ product.url }}" class="product-image-link">
              <img class="product-image" width="300" height="300" loading="lazy" src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}">
            </a>
            <div class="product-info">
              <h3 class="product-title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
              <p class="product-price">{{ product.price | money }}</p>
            </div>
          </div>
        {% else %}
           <p style="grid-column: 1 / -1; text-align: center; padding: 40px 0;">No products found in this collection.</p>
        {% endfor %}
      </div>
    </div>
  </section>

  <div class="pagination-wrapper">
    {{ paginate | default_pagination }}
  </div>
{% endpaginate %}

<style>
  .collection-page-sec {
    width: 100%;
  }

  .collection-header-wrapper {
    padding: 60px 20px;
    border-bottom: 1px solid var(--color-gray-200);
  }

  .collection-header-inner {
    max-width: 1600px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .collection-page-title {
    font-size: clamp(32px, 5vw, 48px);
    margin: 0;
    line-height: 1.1;
  }

  .collection-sort-container {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .collection-sort-container label {
    font-weight: 500;
    font-size: 14px;
  }

  .sort-select {
    padding: 10px 15px;
    border: 1px solid var(--color-gray-200);
    border-radius: 20px;
    font-family: var(--font-body);
    background-color: var(--color-white);
    outline: none;
    cursor: pointer;
  }

  .collection-products-container {
    max-width: 1600px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  @media (min-width: 768px) {
    .products-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .products-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Shared Product Card Styles */
  .product-card {
    display: flex;
    flex-direction: column;
    transition: transform var(--transition-normal);
  }

  .product-card:hover {
    transform: translateY(-5px);
  }

  .product-image-link {
    display: block;
    background-color: #ffffff; /* Solid frame for products */
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 15px;
    aspect-ratio: 1 / 1;
    position: relative;
    box-shadow: var(--shadow-sm);
  }

  .product-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 10px;
    transition: transform var(--transition-slow);
  }

  .product-card:hover .product-image {
    transform: scale(1.05);
  }

  .product-info {
    padding: 0 5px;
  }

  .product-title {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    margin: 0 0 5px 0;
    text-transform: none;
  }

  .product-title a {
    color: var(--color-black);
    text-decoration: none;
  }

  .product-price {
    font-weight: 700;
    margin: 0;
    color: var(--color-gray-800);
  }

  .pagination-wrapper {
    text-align: center;
    padding: 40px 20px 80px;
  }
  
  .pagination-wrapper span, .pagination-wrapper a {
    display: inline-block;
    padding: 8px 16px;
    margin: 0 5px;
    border-radius: 4px;
    background-color: var(--color-gray-100);
    color: var(--color-black);
    text-decoration: none;
  }
  
  .pagination-wrapper .current {
    background-color: var(--color-black);
    color: var(--color-white);
  }
</style>

<script>
  Shopify.queryParams = {};

  // Preserve existing query parameters
  if (location.search.length) {
    var params = location.search.substr(1).split('&');

    for (var i = 0; i < params.length; i++) {
      var keyValue = params[i].split('=');

      if (keyValue.length) {
        Shopify.queryParams[decodeURIComponent(keyValue[0])] = decodeURIComponent(keyValue[1]);
      }
    }
  }

  // Update sort_by query parameter on select change
  document.querySelector('#sort-by').addEventListener('change', function (e) {
    var value = e.target.value;

    Shopify.queryParams.sort_by = value;
    location.search = new URLSearchParams(Shopify.queryParams).toString();
  });
</script>

{% schema %}
{
  "name": "Collection Page",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Header Background Color",
      "default": "#171717"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Header Text Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Collection Page"
    }
  ]
}
{% endschema %}
